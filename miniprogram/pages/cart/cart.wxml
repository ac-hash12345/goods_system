<view class="page">
  <view class="card">
    <view class="cart-header">
      <checkbox checked="{{selectAll}}" bindchange="toggleAll">全选</checkbox>
      <text class="muted">已选商品支持批量下单</text>
    </view>
    <view wx:for="{{cartList}}" wx:key="id" class="cart-item">
      <checkbox checked="{{item.checked !== false}}" data-index="{{index}}" bindchange="toggleItem"></checkbox>
      <image src="{{item.cover}}" class="cart-cover"></image>
      <view class="cart-info">
        <view class="cart-name">{{item.name}}</view>
        <view class="cart-meta">
          <text>￥{{item.price}}</text>
          <text>库存 {{item.stock}}</text>
        </view>
        <view class="cart-op">
          <button size="mini" data-index="{{index}}" data-type="minus" bindtap="changeQuantity">-</button>
          <text>{{item.quantity}}</text>
          <button size="mini" data-index="{{index}}" data-type="add" bindtap="changeQuantity">+</button>
          <button size="mini" class="btn-ghost" data-index="{{index}}" bindtap="removeItem">删除</button>
        </view>
      </view>
    </view>
    <view wx:if="{{cartList.length === 0}}" class="muted empty-tip">购物车空空如也</view>
  </view>

  <view class="cart-footer card">
    <view>
      <text>合计：</text>
      <text class="price">￥{{totalPrice}}</text>
    </view>
    <button class="btn-primary" bindtap="submitOrder">提交订单</button>
  </view>
</view>