.banner {
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: #f3f4f6;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.category-item {
  padding: 14rpx 22rpx;
  background: #eef4ff;
  color: #1677ff;
  border-radius: 999rpx;
}

.goods-item {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e5e7eb;
}

.goods-item:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.goods-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
}

.price {
  color: #e11d48;
  font-weight: 600;
}