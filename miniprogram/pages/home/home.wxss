.banner {
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: #f3f4f6;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.category-item {
  padding: 14rpx 22rpx;
  background: #eef4ff;
  color: #1677ff;
  border-radius: 999rpx;
}

/* 现代双列网格布局 */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 20rpx;
}

.goods-card {
  width: 48%; /* 占据将近一半宽度 */
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.goods-card .goods-cover {
  width: 100%;
  height: 320rpx; /* 大图展示 */
}

.goods-card .goods-info {
  padding: 16rpx;
}

.goods-card .goods-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 40rpx;
  height: 80rpx; /* 固定高度，超出隐藏 */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

.goods-card .goods-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-card .price {
  color: #ff6b00;
  font-size: 32rpx;
  font-weight: 800;
}

.goods-card .stock {
  font-size: 24rpx;
  color: #999;
}
.goods-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
}

.price {
  color: #e11d48;
  font-weight: 600;
}
