<view class="page">
  <view class="card" wx:if="{{goods}}">
    <image src="{{goods.cover}}" mode="aspectFill" class="detail-cover"></image>
    <view class="title">{{goods.name}}</view>
    <view class="price-line">
      <text class="price">￥{{goods.price}}</text>
      <text class="muted">库存 {{goods.stock}}</text>
    </view>
    <view class="detail-content">{{goods.detail}}</view>
    <view class="action-row">
      <button class="btn-ghost" bindtap="addToCart">加入购物车</button>
      <button class="btn-primary" bindtap="createOrder">立即下单</button>
    </view>
  </view>
</view>