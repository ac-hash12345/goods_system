<view class="page">
  <view class="card">
    <view class="search-row">
      <input class="search-input" placeholder="搜索商品" value="{{keyword}}" bindinput="onInput" />
      <button size="mini" class="btn-primary" bindtap="onSearch">搜索</button>
    </view>
  </view>

  <view class="card">
    <view wx:for="{{goodsList}}" wx:key="id" class="goods-item" bindtap="toDetail" data-id="{{item.id}}">
      <image src="{{item.cover}}" mode="aspectFill" class="goods-cover"></image>
      <view class="goods-info">
        <view class="goods-name">{{item.name}}</view>
        <view class="goods-meta">
          <text class="price">￥{{item.price}}</text>
          <text class="muted">库存 {{item.stock}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{goodsList.length === 0}}" class="muted empty-tip">暂无商品</view>
  </view>
</view>