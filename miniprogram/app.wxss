page {
  background: #f5f7fb;
  color: #1f2937;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.muted {
  color: #6b7280;
}

.btn-primary {
  background: #ff6b00;
  color: #ffffff;
  border-radius: 16rpx;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 0, 0.3);
}

.btn-ghost {
  background: #ffffff;
  color: #ff6b00;
  border: 2rpx solid #ff6b00;
  border-radius: 16rpx;
}

.status {
  color: #ff6b00;
}
